# ====== Discord ======
DISCORD_TOKEN=your-bot-token
DISCORD_CLIENT_ID=your-application-id
ADMIN_ROLE_ID=role-id-admin
ADMIN_LOG_CHANNEL_ID=channel-id-log-admin
TICKET_CATEGORY_ID=              # opsional, kategori channel untuk ticket

# ====== IndoSMM Provider ======
INDOSMM_API_URL=https://indosmm.id/api/v2
INDOSMM_API_KEY=your-api-key

# ====== Pembayaran ======
# Opsi A (disarankan): QRIS DINAMIS έΑΦ nominal otomatis sesuai tagihan saat di-scan.
# Isi dengan payload QRIS STATIS kamu (string di dalam gambar QRIS, diawali "00020101...").
# Cara ambil: decode gambar QRIS kamu pakai QR reader / scanner apa pun, salin teksnya.
QRIS_STATIC_PAYLOAD=00020101021126...

# Opsi B (fallback): gambar QRIS statis biasa (user ketik nominal manual).
# Dipakai hanya bila QRIS_STATIC_PAYLOAD kosong.
QRIS_IMAGE_URL=https://.../qris.png

# ====== Bisnis / Konfigurasi ======
MARKUP_PERCENTAGE=40
LOW_BALANCE_THRESHOLD=50000       # ambang notif saldo IndoSMM menipis (Rupiah)
MIN_ORDER_BILL=10000              # minimum tagihan (Rp) per order; order di bawah ini ditolak. 0 = nonaktif
MAX_ACTIVE_TICKETS_PER_USER=5     # maks ticket aktif per user (boleh beda platform sekaligus). 0 = tanpa batas
REFILL_DEFAULT_DAYS=30            # default masa garansi (hari) utk layanan refill yg harinya tak tercantum di nama. 0 = tanpa default
TICKET_AUTOCLOSE_HOURS=24         # jeda (jam) sebelum tiket order selesai ditutup otomatis. 0 = tutup segera
TZ=Asia/Jakarta

# ====== Database (WAJIB untuk Prisma CLI: generate & db push) ======
DATABASE_URL=file:./dev.db

# ====== Testimoni & Monitoring (opsional) ======
# Channel untuk auto-post testimoni pembeli. Hanya rating bintang 4 & 5 yang diposting.
# Kosongkan untuk menonaktifkan (review tetap disimpan & masuk /admin stats).
TESTIMONIAL_CHANNEL_ID=
# URL health-check untuk monitor uptime (mis. healthchecks.io / UptimeRobot push).
HEALTHCHECK_URL=

# ====== Emoji (SEMUA opsional) ======
# Semua variabel emoji ini opsional. Jika tidak diisi, bot pakai emoji default (unicode) di bawah.
# Untuk pakai EMOJI CUSTOM server Discord, isi dengan format:
#   - statis   : <:nama:1234567890>
#   - animasi  : <a:nama:1234567890>
# (Ambil ID-nya: ketik \:namaemoji: di Discord lalu tambahkan backslash di depannya untuk melihat kodenya.)

