# ====== Discord ======
DISCORD_TOKEN=your-bot-token
DISCORD_CLIENT_ID=your-application-id
ADMIN_ROLE_ID=role-id-admin
ADMIN_LOG_CHANNEL_ID=channel-id-log-admin
TICKET_CATEGORY_ID=              # opsional, kategori channel untuk ticket

# ====== IndoSMM Provider ======
INDOSMM_API_URL=https://indosmm.id/api/v2
INDOSMM_API_KEY=your-api-key

# ====== Pembayaran ======
QRIS_IMAGE_URL=https://.../qris.png

# ====== Bisnis / Konfigurasi ======
MARKUP_PERCENTAGE=40
LOW_BALANCE_THRESHOLD=50000       # ambang notif saldo IndoSMM menipis (Rupiah)
TZ=Asia/Jakarta

# ====== Database (WAJIB untuk Prisma CLI: generate & db push) ======
DATABASE_URL=file:./dev.db
